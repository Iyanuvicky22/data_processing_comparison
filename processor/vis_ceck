def viz_data(df, columns=None):
    """
    Function to visualize dataframes
    and check for outliers.
    """
    try:
        if isinstance(df, pd.DataFrame):
            if columns is None:
                columns = df.columns.tolist()
                for col in columns:
                    fig = px.box(df, col)
                    fig.show()
            else:
                for col in columns:
                    fig = px.box(df, col)
                    fig.show()
        elif isinstance(df, pl.DataFrame):
            if columns is None:
                columns = df.columns
                for col in columns:
                    fig = px.box(df, col)
                    fig.show()
            else:
                for col in columns:
                    fig = px.box(df, col)
                    fig.show()
    except AttributeError as e:
        print(f'Data loaded is not a polars or pandas dataframe.\
        It is {e}')


def check_outliers_info(df, col):
    """
    Finds Outliers in a column

    Args:
        df (Dataframe): Pandas or Polars Dataframe
    """
    q1 = df[col].quantile(0.25)
    q3 = df[col].quantile(0.75)

    iqr = q3-q1

    outliers = df[col][((df[col] < (q1 - 1.5 * iqr)) | (df[col] 
                > (q3 + 1.5 * iqr)))]

    num_of_outliers = str(len(outliers))
    max_outlier = str(outliers.max())
    min_outlier = str(outliers.min())
    print(outliers)

    return f'\t\tColumn Name: {df.columns}\n\
             Total Outliers: {num_of_outliers}\n\
             Max Outlier Value: {max_outlier}\n\
             Min Outlier Value: {min_outlier}\n'


